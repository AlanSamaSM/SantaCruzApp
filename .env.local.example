# NEXT_PUBLIC_QR_VALUE — Valor del QR que la cámara de la reja espera leer
NEXT_PUBLIC_QR_VALUE="SANTACRUZ-ACCESS-2730"

# NEXT_PUBLIC_MAPBOX_TOKEN — Token de Mapbox (obtener en mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=

# NEXT_PUBLIC_SITE_URL — URL base del sitio (se configura en Vercel automáticamente)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
